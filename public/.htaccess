<IfModule mod_rewrite.c>
    Options -Indexes
    RewriteEngine On
    RewriteBase /

    # Pass the Authorization header through to PHP. Apache/CGI strips it by default,
    # which would silently break Bearer-token (api-auth) authentication.
    # Authorization header'ını PHP'ye geçir. Apache/CGI bunu varsayılan olarak düşürür;
    # bu da Bearer-token (api-auth) kimlik doğrulamasını sessizce bozardı.
    RewriteCond %{HTTP:Authorization} .
    RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [QSA,L]
</IfModule>
