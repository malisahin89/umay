# Application
APP_NAME=Umay
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_LOCALE=tr
APP_TIMEZONE=Europe/Istanbul

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=umay
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# Cache
CACHE_PREFIX=umay_
CACHE_TTL=3600

# Session
SESSION_LIFETIME=30
SESSION_COOKIE=umay_session
SESSION_SECURE=false
SESSION_SAME_SITE=Strict

# Mail — only the 'log' transport ships by default (writes mail to storage/logs).
# For real delivery, add a custom transport in config/mail.php (see comments there).
MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@localhost
MAIL_FROM_NAME=Umay

# API
API_PREFIX=/api
CORS_ORIGIN=*

# Security
# Trusted reverse-proxy / load-balancer IPs (comma separated). Only these are
# allowed to set the real client IP via X-Forwarded-For. Set to your proxy's
# address in production so clients cannot spoof their IP for throttling/logging.
TRUSTED_PROXIES=127.0.0.1,::1

# Profiler
PROFILER_ENABLED=true
PROFILER_IP_WHITELIST=127.0.0.1,::1
PROFILER_MAX_ENTRIES=200
PROFILER_TTL=7200
